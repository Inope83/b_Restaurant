# =============================================
# .env.example — copy this to .env and fill in
# =============================================
# NEVER commit .env to GitHub!

# Django secret key — generate a new one at:
# https://djecrety.ir/ or run:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Debug mode — set to False in production
DEBUG=True

# Allowed hosts — comma-separated
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave as-is for SQLite, or use PostgreSQL in production)
# DATABASE_URL=postgres://user:password@localhost:5432/restaurant_db

# Email settings (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
